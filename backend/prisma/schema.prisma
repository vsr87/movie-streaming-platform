generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Movie {
  id        String    @id @default(uuid())
  title     String
  file_name String?
  synopsis  String?
  genres    String    // Ex: "Ação", "Terror", "Comédia", "Documentário"
  isPopular Boolean   @default(false) // Fundamental para usuário novo ou sem histórico
  isDeleted Boolean?
  duration  String?
  director  String?
  cast      String?
  createdAt DateTime  @default(now())
  history   History[] // Relacionamento: Um filme pode estar no histórico de vários usuários
}

model Playlist {
  id        String   @id @default(uuid())
  name      String
  userId    String
  movies    String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  password  String?  // Se faz opcional devido ao cadastro de usuário via Google
  googleId  String?  @unique // opcional pois pode ser feito o cadastro tanto por meio do registro de email e senha como via Google
  avatarUrl String?  // Esse campo serve para caso o usuário queria ter uma foto de perfil
  createdAt DateTime @default(now()) // Serve para registrar o momento que o usuário realizou o cadastro
  history   History[] // Relacionamento: Um usuário tem muitos registros no histórico
  role      String   @default("usuario")  // cargo do usuário
}

model History {
  id        String   @id @default(uuid())
  userId    String
  movieId   String
  watchedAt DateTime @default(now()) // Fundamental para a regra dos "últimos 7 dias"

  // Configurações de chaves estrangeiras (ligações entre as tabelas)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
}
