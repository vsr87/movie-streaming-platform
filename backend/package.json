{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node src/index.ts",
    "test:login": "cucumber-js ../features/user_login_service.feature --require-module ts-node/register --require tests/step_definitions/userLogin.steps.ts",
    "test:signin": "npm run test:signup && npm run test:login",
    "test": "npm run test:unit && npm run test:integration && npm run test:e2e && npm run test:cucumber",
    "test:unit": "node --import tsx --test src/**/*.spec.ts",
    "test:unit:jest": "jest tests/units",
    "test:integration": "node --import tsx --test src/**/*.integration.spec.ts",
    "test:e2e": "node --import tsx --test src/**/*.e2e.spec.ts",
    "test:cucumber": "cucumber-js ../features/userSignUp.feature ../features/recommendation.feature --require-module ts-node/register --require tests/step_definitions/**/*.ts",
    "test:cucumber:lessl": "cucumber-js -p lessl --tags '@player or @metadata'",
    "test:delete": "NODE_ENV=test cucumber-js --require-module ts-node/register --require tests/step_definitions/**/*.ts --tags @test-delete",
    "test:deleteservice": "cucumber-js --require-module ts-node/register --require 'tests/step_definitions/**/*.ts' --tags '@test-delete-service'",
    "test:gui": "NODE_ENV=test cucumber-js --require-module ts-node/register --require tests/step_definitions/**/*.ts --tags \"@gui\"",
    "test:signup": "NODE_ENV=test cucumber-js --require-module ts-node/register --require tests/step_definitions/**/*.ts --tags \"@test-signup\"",
    "test:signupservice": "NODE_ENV=test cucumber-js ../features/userSignUp.feature --require-module ts-node/register --require tests/step_definitions/**/*.ts --tags \"@test-signup-service\"",
    "test:cucumber:implemented": "cucumber-js -p implemented",
    "test:movies": "NODE_ENV=test cucumber-js -p movies"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "axios": "^1.16.1",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "google-auth-library": "^10.6.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.9.0",
    "@prisma/client": "^6.19.3",
    "@types/bcrypt": "^6.0.0",
    "@types/chai": "^5.2.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "chai": "^6.2.2",
    "dotenv": "^17.4.2",
    "jest": "^30.4.2",
    "jsonwebtoken": "^9.0.3",
    "nodemon": "^3.1.14",
    "prisma": "^6.19.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3"
  }
}
